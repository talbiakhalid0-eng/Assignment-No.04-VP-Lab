@page "/"

<PageTitle>Home Console</PageTitle>

<div class="interactive-card-frame text-center animate-fade-in" style="max-width: 650px; margin-top: 2rem;">
    <div class="card-header-accent" style="background-color: #4e73df;">
        System Command Center
    </div>

    <div class="card-body-content py-5">
        <div class="mb-4">
            <i class="bi bi-cpu-fill text-primary" style="font-size: 3.5rem; display: block; opacity: 0.85;"></i>
        </div>

        <h1 class="fw-bold mb-2" style="color: #2e3d66; font-size: 2.2rem;">
            Welcome back, Operator!
        </h1>

        <p class="text-muted mx-auto mb-4" style="max-width: 450px; font-size: 1.05rem; line-height: 1.6;">
            All laboratory modules and application pipelines are integrated successfully. Use the left navigation sidebar matrix to switch between active sub-systems.
        </p>

        <hr class="my-4" style="border-color: #e3e6f0; max-width: 80%;">

        <div class="d-inline-flex align-items-center gap-2 px-3 py-2 bg-light rounded border">
            <span class="spinner-grow spinner-grow-sm text-success" role="status"></span>
            <span class="font-monospace small text-uppercase text-secondary fw-bold" style="letter-spacing: 0.5px;">
                Environment Status: Online // Stable
            </span>
        </div>
    </div>
</div>